{
  "name": "nibir-fashion",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('node:fs');['package-lock.json','yarn.lock'].forEach(f=>{if(fs.existsSync(f)) fs.rmSync(f,{force:true});});const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1);}\"",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "build:desktop": "corepack pnpm --filter @workspace/desktop-shell build",
    "dist:desktop": "corepack pnpm --filter @workspace/desktop-shell dist",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
