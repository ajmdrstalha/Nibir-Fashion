# Copy this file to .env before running Docker locally.

# PostgreSQL container settings
POSTGRES_DB=nibir_fashion
POSTGRES_USER=fashion
POSTGRES_PASSWORD=fashion
POSTGRES_PORT=12502

# Host ports exposed by docker compose
BACKEND_PORT=12501
FRONTEND_PORT=12500

# Used when running the backend directly on Windows outside Docker.
DATABASE_URL=postgres://fashion:fashion@localhost:12502/nibir_fashion

# Browser-facing API URL used by the Vite frontend.
# Azure deployment example:
VITE_API_BASE_URL=http://98.70.41.172:12501
# Local Windows alternative:
# VITE_API_BASE_URL=http://localhost:12501

# Auth settings for the web backend.
JWT_SECRET=change-this-local-dev-secret
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
